{
  "name": "relatasql-mcp",
  "version": "1.0.0",
  "description": "Official Model Context Protocol server for RelataSQL — lets LLM clients list database connections, inspect schemas, and execute SQL queries through a user's RelataSQL workspace.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "relatasql-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "relatasql",
    "sql",
    "database"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
